    <script type="text/javascript">
        const downloadLimitTriggered = false;
        const buttonFree = $('.btn-submit-free');
        const downloadTimerMsg = $('.download-timer-msg');
        let seconds = 15;

        function formatCountdown(totalSeconds) {
            const minutes = ~~((totalSeconds % 3600) / 60);
            const seconds = ~~totalSeconds % 60;
            return ((minutes > 0) ? (String(minutes).padStart(2, '0') + 'm ') : '') + (seconds < 10 ? '0' : '') + seconds + 's';
        }

        const totalSecondsForRing = seconds;
        const circumference = 2 * Math.PI * 32;
        const circle = document.getElementById('progressCircle');
        if (circle) {
            circle.style.strokeDasharray = circumference;
            circle.style.strokeDashoffset = 0;
        }

        let countdownTimer;
        function countDown() {
            if (seconds === 0) {
                document.getElementById('btnText').textContent = 'Free Download';
                const spinner = document.getElementById('spinnerIcon');
                if (spinner) spinner.style.display = 'none';
                buttonFree.addClass('ready');
                buttonFree.attr('type', 'submit');
                if (circle) {
                    circle.style.stroke = '#28a745';
                    circle.style.strokeDashoffset = 0;
                }
                clearTimeout(countdownTimer);
            } else {
                $('.download-timer-seconds').html(formatCountdown(seconds));
                if (circle) {
                    const progress = (totalSecondsForRing - seconds) / totalSecondsForRing;
                    circle.style.strokeDashoffset = circumference * (1 - progress);
                }
            }
            seconds--;
        }

        $(document).ready(function() {
            function startCountdown() {
                $(this).attr('disabled', true);
                countdownTimer = setInterval('countDown()', 1000);
            }
            startCountdown();

            if (downloadLimitTriggered === true) {
                downloadTimerMsg.html('before downloading again');
            }
        });
    </script>

    
            

